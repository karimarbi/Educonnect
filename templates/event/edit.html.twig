
{% block title %}Edit Event{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Edit Event</h3>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.titre, 'Titre de l\'événement', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.titre, {'attr': {'class': 'form-control rounded-pill shadow-sm', 'placeholder': 'Entrez le titre'}}) }}
                            {{ form_errors(form.titre) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.dateDebut, 'Date de début', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control rounded-pill shadow-sm'}}) }}
                            {{ form_errors(form.dateDebut) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.dateFin, 'Date de fin', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control rounded-pill shadow-sm'}}) }}
                            {{ form_errors(form.dateFin) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.lieu, 'Lieu', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.lieu, {'attr': {'class': 'form-control rounded-pill shadow-sm', 'placeholder': 'Entrez le lieu'}}) }}
                            {{ form_errors(form.lieu) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control shadow-sm', 'rows': '4', 'placeholder': 'Entrez une description'}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.duree, 'Durée (en heures)', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.duree, {'attr': {'class': 'form-control rounded-pill shadow-sm', 'placeholder': 'Durée en heures'}}) }}
                            {{ form_errors(form.duree) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.nombreMaxParticipants, 'Nombre maximal de participants', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.nombreMaxParticipants, {'attr': {'class': 'form-control rounded-pill shadow-sm', 'placeholder': 'Nombre maximum'}}) }}
                            {{ form_errors(form.nombreMaxParticipants) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.imageFile, 'Image de l\'événement', {'label_attr': {'class': 'fw-bold form-label'}}) }}
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control shadow-sm'}}) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                        <div class="text-center">
                            <button type="submit" class="btn btn-success px-4 py-2 rounded-pill shadow-sm">{{ button_label|default('Update') }}</button>
                            <a href="{{ path('app_event_index') }}" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">Retour à la liste</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
